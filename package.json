{
  "name": "travelog",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "npm run dev --prefix web",
    "dev:server": "npm run dev --prefix server",
    "install:all": "npm install --prefix web && npm install --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
